# GPT Image2 token：只允许放在后端，不要写进前端
# 内部 OpenAPI 鉴权格式为 Authorization: Bearer {API_KEY}，这里直接填 token 本体即可。
GPT_IMAGE2_API_KEY=你的token
GPT_IMAGE2_API_BASE_URL=http://v2.open.venus.oa.com/llmproxy
GPT_IMAGE2_GENERATIONS_PATH=/images/generations
GPT_IMAGE2_EDITS_PATH=/images/edits
GPT_IMAGE2_MODEL=gpt-image-2
GPT_IMAGE2_QUALITY=medium
# gpt-image-2 接受任意符合「宽高均 16 倍数 / 最长边 ≤3840 / 比例 ≤3:1 / 总像素 655360–8294400」的尺寸。
# 留空即按目标比例动态计算最贴近的合法分辨率（推荐）。
# 仅在网关只接受固定档位（如 gpt-image-1）时才填白名单：1024x1024,1536x1024,1024x1536
GPT_IMAGE2_ALLOWED_SIZES=

# GPT5.5 视觉理解 / OCR 试验配置；默认复用 GPT_IMAGE2_API_KEY，也可单独配置 VISION_API_KEY
# VISION_API_KEY=你的视觉模型token
VISION_API_BASE_URL=http://v2.open.venus.oa.com/chatproxy
VISION_CHAT_PATH=/chat/completions
VISION_MODEL=gpt-5.5

# 服务监听地址与端口；DevCloud / 工蜂 IDE 端口转发需要监听 0.0.0.0
HOST=0.0.0.0
PORT=3000

# 允许访问后端的前端地址，多个地址用英文逗号分隔。
# 如果由本 Node 服务同源托管前端，可留空；如果前后端分域部署，请填写正式前端域名。
ALLOWED_ORIGINS=
